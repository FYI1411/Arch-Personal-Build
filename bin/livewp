#!/bin/bash
wp_dir=~/wallpaper/
num=1
# when num > the files count => shuf return the max num
# else only return 1 file
cmd='mpvpaper -so'
opt='--loop-playlist --no-audio'
last_wp=$(ps ax ww | grep -v grep | \
grep mpvpaper | awk -F '/' '{print $NF}')
# space in case file doesn't exist
if [[ ! -f "$wp_dir$last_wp" ]]; then
	last_wp=" "
fi

main() {
	# This script toggles the wp if there's only 1
	# Kill last wp if exist
	killall mpvpaper hyprpaper > /dev/null 2>&1
	if [[ $# -eq 0 ]]; then
		# Loop multiple wps randomly
		$cmd "$opt" '*' $(find ${wp_dir} -type f -wholename "*.mp4" \
		! -wholename "*$last_wp" | shuf -n 1) > /dev/null 2>&1 
	else
		$cmd "$opt" '*' "$@" > /dev/null 2>&1 # Loop the wp
	fi
	# Fallback to static wallpaper
    if ! pgrep -x "mpvpaper" > /dev/null && ! pgrep -x "hyprpaper" > /dev/null; then
        hyprpaper > /dev/null 2>&1
    fi
}

main "$@"
