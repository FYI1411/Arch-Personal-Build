#!/bin/bash

# Extract only the numeric value of the volume (stripping trailing % signs)
volume=$(pactl get-sink-volume @DEFAULT_SINK@ | awk '{ print $5 }' | tr -d '%')
mute=$(pactl get-sink-mute @DEFAULT_SINK@ | awk '{ print $2 }')

# Use standard freedesktop hint for replacement and transient (don't save to history)
hint="-h string:x-canonical-private-synchronous:volume -e"

if [[ "$volume" -eq 0 || "$mute" == "yes" ]]; then
    # Show the sound muted notification
    notify-send -a "changeVolume" -u low -i audio-volume-muted $hint "Volume muted"
else
    # Show the volume notification with working progress bar value
    notify-send -a "changeVolume" -u low -i audio-volume-high $hint \
    -h int:value:"$volume" "Volume: ${volume}%"
fi

